#!/usr/bin/env bash

# YouTube Audio Downloader - Main CLI Script
# Usage: ./ytdl [command] [options]

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$SCRIPT_DIR"

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m' # No Color

# Helper functions
print_header() {
    echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo -e "${CYAN}  $1${NC}"
    echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
}

print_success() {
    echo -e "${GREEN}✓${NC} $1"
}

print_error() {
    echo -e "${RED}✗${NC} $1"
}

print_info() {
    echo -e "${BLUE}ℹ${NC} $1"
}

print_warning() {
    echo -e "${YELLOW}⚠${NC} $1"
}

# Show help
show_help() {
    cat << EOF
$(print_header "YouTube Audio Downloader CLI")

${GREEN}USAGE:${NC}
    ./ytdl <command> [options]

${GREEN}COMMANDS:${NC}
    ${CYAN}genres${NC}                      List all available music genres
    ${CYAN}browse${NC} <genre> [limit]      Browse music by genre
    ${CYAN}download${NC} <genre> [options]  Download music by genre
    ${CYAN}get${NC} <url> [options]         Download from URL
    ${CYAN}search${NC} <query> [limit]      Search YouTube
    ${CYAN}cache${NC}                       View cache statistics
    ${CYAN}clear${NC} [category]            Clear cache
    ${CYAN}help${NC}                        Show this help

${GREEN}EXAMPLES:${NC}
    ${YELLOW}# List all genres${NC}
    ./ytdl genres

    ${YELLOW}# Browse lofi music (5 results)${NC}
    ./ytdl browse lofi

    ${YELLOW}# Browse jazz with 10 results${NC}
    ./ytdl browse jazz 10

    ${YELLOW}# Download first lofi track${NC}
    ./ytdl download lofi

    ${YELLOW}# Download 3rd jazz track${NC}
    ./ytdl download jazz --index 3

${YELLOW}# Download 5 classical tracks${NC}
    ./ytdl download classical --count 5

    ${YELLOW}# Download only short tracks (under 10 min)${NC}
    ./ytdl download lofi --count 5 --max-duration 600

    ${YELLOW}# Download tracks 3-15 minutes long${NC}
    ./ytdl download jazz --count 5 --min-duration 180 --max-duration 900

    ${YELLOW}# Download from URL${NC}
    ./ytdl get "https://www.youtube.com/watch?v=VIDEO_ID"

    ${YELLOW}# Search with duration filter${NC}
    ./ytdl search "epic orchestral music" 10 --max-duration 1800

    ${YELLOW}# Force re-download (skip cache)${NC}
    ./ytdl download lofi --force

    ${YELLOW}# View cache stats${NC}
    ./ytdl cache

    ${YELLOW}# Clear lofi cache${NC}
    ./ytdl clear lofi

${GREEN}OPTIONS:${NC}
    --index N           Download Nth search result (default: 1)
    --count N           Download N tracks
    --limit N           Number of search results (default: 5)
    --min-duration N    Minimum duration in seconds
    --max-duration N    Maximum duration in seconds
    --force             Skip cache check, re-download
    --output DIR        Output directory (default: downloads)

${GREEN}GENRE CATEGORIES:${NC}
    Electronic: lofi, edm, techno, house, synthwave, ambient...
    Jazz: jazz, smooth_jazz, bebop, cool_jazz...
    Rock: rock, classic_rock, indie_rock, metal...
    Classical: classical, baroque, piano, violin...
    And 100+ more! Use './ytdl genres' to see all.

${GREEN}NOTES:${NC}
    • Downloads are cached per genre to prevent duplicates
    • MP3 files saved to downloads/ directory
    • Use --force to bypass cache
    • Cache stored in downloads/.cache/

EOF
}

# List genres
list_genres() {
    print_header "Available Music Genres (104 total)"
    mix run -e 'YoutubeAudioDl.Music.print_genres()'
}

# Browse genre
browse_genre() {
    local genre="$1"
    shift
    local limit=5
    local min_dur=""
    local max_dur=""

    # Parse options
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --min-duration)
                min_dur="$2"
                shift 2
                ;;
            --max-duration)
                max_dur="$2"
                shift 2
                ;;
            [0-9]*)
                # Positional limit argument
                limit="$1"
                shift
                ;;
            *)
                shift
                ;;
        esac
    done

    if [[ -z "$genre" ]]; then
        print_error "Genre required. Usage: ./ytdl browse <genre> [limit] [options]"
        echo "Run './ytdl genres' to see available genres"
        exit 1
    fi

    # Build Elixir options
    local opts="limit: ${limit}"
    [[ -n "$min_dur" ]] && opts="$opts, min_duration: ${min_dur}"
    [[ -n "$max_dur" ]] && opts="$opts, max_duration: ${max_dur}"

    local filter_msg=""
    [[ -n "$min_dur" ]] && filter_msg=" (min: ${min_dur}s)"
    [[ -n "$max_dur" ]] && filter_msg="${filter_msg} (max: ${max_dur}s)"

    print_header "Browsing: $genre (limit: $limit)${filter_msg}"
    mix run -e "
    genre_name = :${genre} |> to_string() |> String.upcase()
    case YoutubeAudioDl.Music.search(:${genre}, [${opts}]) do
      {:ok, videos} ->
        IO.puts(\"\\n🎵 Genre: \#{genre_name}\")
        YoutubeAudioDl.Search.print_results(videos)
      {:error, reason} ->
        IO.puts(\"Error: \#{inspect(reason)}\")
    end
    "
}

# Download by genre
download_genre() {
    local genre="$1"
    shift

    if [[ -z "$genre" ]]; then
        print_error "Genre required. Usage: ./ytdl download <genre> [options]"
        exit 1
    fi

    local index=1
    local count=""
    local force="false"
    local output="downloads"
    local min_dur=""
    local max_dur=""

    # Parse options
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --index)
                index="$2"
                shift 2
                ;;
            --count)
                count="$2"
                shift 2
                ;;
            --min-duration)
                min_dur="$2"
                shift 2
                ;;
            --max-duration)
                max_dur="$2"
                shift 2
                ;;
            --force)
                force="true"
                shift
                ;;
            --output)
                output="$2"
                shift 2
                ;;
            *)
                print_warning "Unknown option: $1"
                shift
                ;;
        esac
    done

    # Build filter options
    local filter_opts=""
    [[ -n "$min_dur" ]] && filter_opts="${filter_opts}min_duration: ${min_dur}, "
    [[ -n "$max_dur" ]] && filter_opts="${filter_opts}max_duration: ${max_dur}, "

    if [[ -n "$count" ]]; then
        # Download multiple with filtering
        print_header "Downloading $count tracks from: $genre"
        [[ -n "$min_dur" || -n "$max_dur" ]] && echo "🔍 Duration filter: min=${min_dur:-none} max=${max_dur:-none}"

        mix run -e "
        # Search with duration filters
        case YoutubeAudioDl.Music.search(:${genre}, [${filter_opts}limit: ${count}]) do
          {:ok, videos} ->
            actual = length(videos)
            if actual < ${count}, do: IO.puts(\"⚠️  Only found \#{actual} videos matching filters\")

            category = \"${genre}\"
            results = Enum.with_index(videos, 1)
            |> Enum.map(fn {video, idx} ->
              IO.puts(\"\\n[\#{idx}/\#{actual}] Downloading: \#{video.title}\")
              YoutubeAudioDl.download_audio(video.url, output_dir: \"${output}\", force: ${force}, category: category)
            end)

            successful = Enum.count(results, &match?({:ok, _}, &1))
            skipped = Enum.count(results, &match?({:error, :already_downloaded}, &1))
            IO.puts(\"\\n📊 Summary: \#{successful} downloaded, \#{skipped} skipped\")

          {:error, reason} ->
            IO.puts(\"Error: \#{inspect(reason)}\")
        end
        "
    else
        # Download single with filtering
        print_header "Downloading from: $genre (index: $index)"
        [[ -n "$min_dur" || -n "$max_dur" ]] && echo "🔍 Duration filter: min=${min_dur:-none} max=${max_dur:-none}"

        mix run -e "
        case YoutubeAudioDl.Music.search(:${genre}, [${filter_opts}limit: ${index}]) do
          {:ok, videos} ->
            video = Enum.at(videos, ${index} - 1)
            if video do
              IO.puts(\"\\nDownloading: \#{video.title}\")
              IO.puts(\"Channel: \#{video.channel}\")
              IO.puts(\"Duration: \#{YoutubeAudioDl.Search.format_duration(video.duration)}\\n\")
              YoutubeAudioDl.download_audio(video.url, output_dir: \"${output}\", force: ${force}, category: \"${genre}\")
            else
              IO.puts(\"Error: No video found at index ${index}\")
            end
          {:error, reason} ->
            IO.puts(\"Error: \#{inspect(reason)}\")
        end
        "
    fi
}

# Download from URL
download_url() {
    local url="$1"
    shift

    if [[ -z "$url" ]]; then
        print_error "URL required. Usage: ./ytdl get <url> [options]"
        exit 1
    fi

    local force="false"
    local output="downloads"
    local category="general"

    # Parse options
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --force)
                force="true"
                shift
                ;;
            --output)
                output="$2"
                shift 2
                ;;
            --category)
                category="$2"
                shift 2
                ;;
            *)
                print_warning "Unknown option: $1"
                shift
                ;;
        esac
    done

    print_header "Downloading from URL"
    mix run -e "YoutubeAudioDl.download_audio(\"${url}\", force: ${force}, output_dir: \"${output}\", category: \"${category}\")"
}

# Search YouTube
search_youtube() {
    local query="$1"
    shift
    local limit=5
    local min_dur=""
    local max_dur=""

    # Parse options
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --min-duration)
                min_dur="$2"
                shift 2
                ;;
            --max-duration)
                max_dur="$2"
                shift 2
                ;;
            --limit)
                limit="$2"
                shift 2
                ;;
            [0-9]*)
                # Positional limit
                limit="$1"
                shift
                ;;
            *)
                shift
                ;;
        esac
    done

    if [[ -z "$query" ]]; then
        print_error "Query required. Usage: ./ytdl search <query> [limit] [options]"
        exit 1
    fi

    # Build options
    local opts="limit: ${limit}"
    [[ -n "$min_dur" ]] && opts="$opts, min_duration: ${min_dur}"
    [[ -n "$max_dur" ]] && opts="$opts, max_duration: ${max_dur}"

    local filter_msg=""
    [[ -n "$min_dur" ]] && filter_msg=" (min: ${min_dur}s)"
    [[ -n "$max_dur" ]] && filter_msg="${filter_msg} (max: ${max_dur}s)"

    print_header "Searching: $query (limit: $limit)${filter_msg}"
    mix run -e "
    {:ok, results} = YoutubeAudioDl.Search.search(\"${query}\", [${opts}])
    YoutubeAudioDl.Search.print_results(results)
    "
}

# Show cache stats
show_cache() {
    print_header "Cache Statistics"
    mix run -e '
    stats = YoutubeAudioDl.Cache.all_stats()

    IO.puts("\nTotal Downloads: #{stats.total_downloads}")
    IO.puts("Total Categories: #{stats.total_categories}\n")

    if length(stats.categories) > 0 do
      IO.puts("By Category:")
      Enum.each(stats.categories, fn cat ->
        IO.puts("  #{String.pad_trailing(cat.category, 20)} #{cat.total_downloads} downloads")
      end)
    else
      IO.puts("No cached downloads yet.")
    end
    '
}

# Clear cache
clear_cache() {
    local category="${1:-all}"

    if [[ "$category" == "all" ]]; then
        print_warning "This will clear ALL caches. Are you sure? (y/N)"
        read -r response
        if [[ "$response" =~ ^[Yy]$ ]]; then
            print_header "Clearing all caches"
            rm -rf downloads/.cache/
            print_success "All caches cleared"
        else
            print_info "Cancelled"
        fi
    else
        print_header "Clearing cache: $category"
        mix run -e "YoutubeAudioDl.Cache.clear_all(\"${category}\")"
        print_success "Cache cleared for: $category"
    fi
}

# Main command router
main() {
    if [[ $# -eq 0 ]]; then
        show_help
        exit 0
    fi

    local command="$1"
    shift

    case "$command" in
        help|--help|-h)
            show_help
            ;;
        genres|list)
            list_genres
            ;;
        browse|b)
            browse_genre "$@"
            ;;
        download|dl|d)
            download_genre "$@"
            ;;
        get|url)
            download_url "$@"
            ;;
        search|s)
            search_youtube "$@"
            ;;
        cache|stats)
            show_cache
            ;;
        clear|clean)
            clear_cache "$@"
            ;;
        *)
            print_error "Unknown command: $command"
            echo ""
            show_help
            exit 1
            ;;
    esac
}

main "$@"
